APP_NAME=Converra AI
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=false

HOST=0.0.0.0
PORT=8000

LOG_LEVEL=INFO

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

DATABASE_URL=postgresql+psycopg://converra:change-me@localhost:5432/converra_ai

# Comma-separated browser origins and valid Host headers.
CORS_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_UPLOAD_SIZE_BYTES=10485760

GROQ_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=rule_based
LLM_MODEL_NAME=gpt-4o-mini
VOICE_STT_PROVIDER=rule_based
VOICE_TTS_PROVIDER=rule_based

CHROMA_PATH=./chroma_db
EMBEDDING_PROVIDER=deterministic
# Set EMBEDDING_PROVIDER=sentence_transformers and install backend/requirements-ml.txt for ML embeddings.
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
